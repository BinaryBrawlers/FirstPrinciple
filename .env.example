# ──────────────────────────────────────────────────────────────────────────────
# MindForge — Environment Variables
# Copy this file to .env and fill in your Mistral API key.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────
#
# Setup: get your Mistral API key at https://console.mistral.ai/api-keys
# No Cognee cloud account needed — Cognee runs locally.
#
# IMPORTANT: Both LLM and embedding must be configured together.
# If only one is set, Cognee silently falls back to OpenAI for the other.
# ──────────────────────────────────────────────────────────────────────────────

# ── Mistral API key ───────────────────────────────────────────────────────────
# Used for both LLM generation and embeddings.
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Cognee — LLM (Mistral via LiteLLM) ───────────────────────────────────────
# Cognee routes through LiteLLM; the "mistral/" prefix is required.
LLM_PROVIDER=litellm
LLM_MODEL=mistral/mistral-small-latest
# Must match MISTRAL_API_KEY above
LLM_API_KEY=your_mistral_api_key_here

# ── Cognee — Embeddings (Mistral) ─────────────────────────────────────────────
# mistral-embed is Mistral's dedicated embedding model (1024 dimensions).
EMBEDDING_PROVIDER=mistral
EMBEDDING_MODEL=mistral-embed
EMBEDDING_DIMENSIONS=1024
# Falls back to LLM_API_KEY if not set — you can omit this if using same key
# EMBEDDING_API_KEY=your_mistral_api_key_here

# ── FastAPI server (optional overrides) ───────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000

# ── Cognee telemetry (optional) ───────────────────────────────────────────────
# TELEMETRY_DISABLED=true
