# FirstPrinciple — required environment variables
# Copy this file to .env and fill in your values.

# Mistral AI API key (required for LLM and embedding calls)
MISTRAL_API_KEY=your_mistral_api_key_here

# Skip cognee connection test on startup (recommended for local/Docker dev)
# Set to "true" to allow the app to start without a live cognee instance.
COGNEE_SKIP_CONNECTION_TEST=true
