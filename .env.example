# ============================================================
# MindForge — Cognee Configuration
# Copy this file to .env and fill in your Mistral API key.
# NEVER commit .env to version control.
# ============================================================
#
# Get your Mistral API key at: https://console.mistral.ai/api-keys
# No Cognee cloud account needed — all databases run locally.
#
# IMPORTANT: LLM and Embedding must be configured together.
# Cognee silently falls back to OpenAI if either is missing.
# ============================================================

# --- LLM (Mistral Cloud via LiteLLM routing) ---
# The "mistral/" prefix tells LiteLLM to route to Mistral's API.
# Using "custom" provider avoids importing the mistralai SDK inside Cognee.
LLM_PROVIDER=custom
LLM_MODEL=mistral/mistral-small-latest
LLM_API_KEY=your_mistral_api_key_here

# --- Embeddings (Mistral Cloud via LiteLLM routing) ---
# For "custom" provider, EMBEDDING_API_KEY must be set explicitly.
EMBEDDING_PROVIDER=custom
EMBEDDING_MODEL=mistral/mistral-embed
EMBEDDING_DIMENSIONS=1024
EMBEDDING_API_KEY=your_mistral_api_key_here

# --- Skip Cognee connection probe (recommended) ---
COGNEE_SKIP_CONNECTION_TEST=true

# --- Drop unsupported params when routing through LiteLLM ---
LITELLM_DROP_PARAMS=true

# --- Relational Database (Local SQLite — no install needed) ---
DB_PROVIDER=sqlite

# --- Vector Store (Local LanceDB — no install needed) ---
VECTOR_DB_PROVIDER=lancedb

# --- Graph Store (Local Ladybug/Kuzu — no install needed) ---
GRAPH_DATABASE_PROVIDER=ladybug

# --- Storage Paths (update to your absolute project path) ---
SYSTEM_ROOT_DIRECTORY=/home/YOUR_USERNAME/projects/cogneehack/.cognee_system
DATA_ROOT_DIRECTORY=/home/YOUR_USERNAME/projects/cogneehack/.data_storage

# --- Sessions & Caching (Local filesystem) ---
CACHING=true
CACHE_BACKEND=fs

# --- Logging ---
LOG_LEVEL=ERROR
TELEMETRY_DISABLED=true

# --- Mistral API key (used by MindForge agents directly via mistralai SDK) ---
MISTRAL_API_KEY=your_mistral_api_key_here

# --- FastAPI server (optional overrides) ---
# API_HOST=0.0.0.0
# API_PORT=8000
