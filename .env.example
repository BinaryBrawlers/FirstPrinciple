# FirstPrinciple — required environment variables
# Copy this file to .env and fill in your values before starting the application.

# ------------------------------------------------------------------------------
# Mistral API key (required)
# Obtain from https://console.mistral.ai/
# ------------------------------------------------------------------------------
MISTRAL_API_KEY=your_mistral_api_key_here

# ------------------------------------------------------------------------------
# cognee connection test skip (set to "true" in all environments)
# This allows the backend to start without an active cognee server instance.
# Do NOT change this unless you are intentionally running a live cognee server
# and want to validate connectivity on startup.
# ------------------------------------------------------------------------------
COGNEE_SKIP_CONNECTION_TEST=true
